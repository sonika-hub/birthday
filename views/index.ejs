<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>For You | <%= name %></title>
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,wght@1,400;1,700&family=Syncopate:wght@400;700&family=Montserrat:wght@200;400;600&family=Cormorant+Garamond:ital,wght@1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="grain-overlay"></div>
    <div class="progress-container"><div class="progress-bar" id="bar"></div></div>

    <div class="app-container">
        <section class="step active" id="step-1">
            <div class="hero-content">
                <h1 class="main-title">Happy <br><span>Birthday</span></h1>
                <h2 class="name-text"><%= name %></h2>
                <button class="next-btn" onclick="nextStep(2)">Enter the Experience</button>
            </div>
        </section>

        <section class="step" id="step-2">
            <div class="note-card glass-morph">
                <p class="elegant-quote">"May your year be as radiant as your spirit."</p>
                <button class="next-btn" onclick="nextStep(3)">The Collection</button>
            </div>
        </section>

        <section class="step" id="step-3">
            <div class="gallery-container">
                <div class="gallery-grid">
                    <% photos.forEach((img, i) => { %>
                        <div class="glass-frame">
                            <div class="img-wrapper">
                                <img src="/images/<%= img %>" alt="Memory">
                            </div>
                        </div>
                    <% }) %>
                </div>
                <button class="next-btn" onclick="nextStep(4)">Final Spark</button>
            </div>
        </section>

        <section class="step" id="step-4">
            <div id="keepsakeCard" class="finale-content">
                <div class="sparkle-circle" id="btnWrapper">
                    <button id="celebrateBtn">CELEBRATE</button>
                </div>
                <div class="signature-wrap">
                    <div id="finalSignature" class="signature-text"></div>
                </div>
            </div>
            
            <div class="action-buttons">
                <button class="keepsake-btn" id="downloadBtn" style="display:none;" onclick="downloadKeepsake()">↓ Save Keepsake</button>
                <button class="return-btn" id="replayBtn" style="display:none;" onclick="resetAndReturn()">↺ Begin Again</button>
            </div>
            
            <audio id="bgMusic" src="/audio/music.mp3" loop></audio>
        </section>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>